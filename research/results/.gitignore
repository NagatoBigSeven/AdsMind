# Default: ignore everything, then whitelist
*
!.gitignore

# ── Top-level summaries & paper data ──
!*.csv
!*.json
!*.md
!*.tex

# ── Analysis directory ──
!analysis/
!analysis/*

# Canonical merged raw result directories
!canonical_raw/
!canonical_raw/**/result.json
!canonical_raw/**/*.md
!canonical_raw/**/*.json
!canonical_raw/**/*.csv
!canonical_raw/**/
# Canonical raw result directories, including controls and legacy archived raw inputs
!canonical_raw/*
!canonical_raw/*/
!canonical_raw/*/*.csv
!canonical_raw/*/*.json
!canonical_raw/*/*.md
!canonical_raw/*/source_summaries/
!canonical_raw/*/source_summaries/*
!canonical_raw/*/*/
!canonical_raw/*/*/result.json
!canonical_raw/*/*/*/
!canonical_raw/*/*/*/result.json
# ── Dataset directories ──

# Dataset-level summaries

# Ablation: variant dirs + case dirs + result.json only

# One-shot: case dirs + result.json only

# Explicitly exclude per-run artifacts that leak through dir unignore
**/config.json
**/comparison_snapshot.json
**/agent_log.txt
**/artifacts/

# ── Adsorb-Agent MACE comparison (paper-cited, kept at root) ──
!adsorbagent_mace_gpt54/
!adsorbagent_mace_gpt54/*.csv
!adsorbagent_mace_gpt54/*.json

# Note: adsorbagent_mace_gpt4o, mace_large_gpt54, multiseed_gpt54 moved into
# canonical_raw/auxiliary_raw/ on 2026-04-30 (see MIGRATION.md). They are
# whitelisted there via the canonical_raw/** rules above.
