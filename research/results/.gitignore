# Default: ignore everything, then whitelist
*
!.gitignore

# ── Top-level summaries & paper data ──
!*.csv
!*.json
!*.tex

# ── Analysis directory ──
!analysis/
!analysis/*

# Canonical merged raw result directories
!canonical_raw/
!canonical_raw/*
!canonical_raw/*/
!canonical_raw/*/*.csv
!canonical_raw/*/*.json
!canonical_raw/*/*.md
!canonical_raw/*/source_summaries/
!canonical_raw/*/source_summaries/*
!canonical_raw/*/*/
!canonical_raw/*/*/result.json
!canonical_raw/*/*/*/
!canonical_raw/*/*/*/result.json
# ── Dataset directories ──
!gemini_ablation_v1/
!xai_ablation_v2/
!openai_gpt54_ablation_v1/
