# Local render workspaces can produce many large images and Blender caches.
**/.DS_Store
**/__pycache__/

# Keep selected manuscript/draft outputs tracked explicitly; ignore bulk render
# batches unless they are promoted into a paper-facing artifact by force-adding.
panel_b_blender/renders/
panel_b_ovito/renders/
panel_b_comparison/*.png
panel_b_comparison/*.pdf
