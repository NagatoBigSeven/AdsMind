{
  "temperature": 0.0,
  "max_tokens": 4096,
  "timeout_sec": 120,
  "relaxation_mode": "standard",
  "calculator_backend": "mace",
  "mace_device": "cpu",
  "mace_precision": "float32",
  "mace_model": "small",
  "mace_use_dispersion": false,
  "fmax": 0.1,
  "random_seed": 42,
  "manifest_version": "cmu_manifest_v1",
  "user_request_mode": "per-case explicit request string from datasets/cmu20/cmu20_manifest.csv",
  "llm_backend": "openrouter",
  "llm_model": "x-ai/grok-4.3",
  "llm_base_url": "https://openrouter.ai/api/v1",
  "llm_api_key_env_var": "OPENROUTER_API_KEY",
  "platform": "linux-x86_64-cpu-float32",
  "notes": [
    "Grok-4.3 fallback configuration for per-agent ablation only.",
    "Switched from Grok-4 after OpenRouter deprecated Grok-4 on 2026-05-22.",
    "Target model id: x-ai/grok-4.3.",
    "API keys are supplied at runtime and are not stored in this config.",
    "Physics protocol matches frozen_config_grok4_mace_mp0_small.json otherwise."
  ],
  "max_retries": 5,
  "transport_variant": "openrouter"
}
