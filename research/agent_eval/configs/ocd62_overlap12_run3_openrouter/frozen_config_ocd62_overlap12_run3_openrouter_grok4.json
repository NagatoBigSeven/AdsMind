{
  "llm_backend": "openrouter",
  "llm_model": "x-ai/grok-4",
  "llm_base_url": "https://openrouter.ai/api/v1",
  "llm_api_key_env_var": "OPENROUTER_API_KEY",
  "llm_default_headers": {
    "HTTP-Referer": "https://github.com/zongmin/AdsMind",
    "X-Title": "AdsMind OCD62 RUN3 Grok-4"
  },
  "temperature": 0,
  "max_tokens": 4096,
  "timeout_sec": 120,
  "max_retries": 5,
  "relaxation_mode": "standard",
  "calculator_backend": "mace",
  "mace_device": "cpu",
  "mace_precision": "float32",
  "mace_model": "small",
  "mace_use_dispersion": false,
  "fmax": 0.1,
  "random_seed": 42,
  "platform": "EPFL-LIACPC12-cpu-float32",
  "manifest_version": "ocd62_overlap12_run3_manifest_v1",
  "transport_variant": "openrouter",
  "user_request_mode": "per-case explicit request string from datasets/ocd62_overlap12/ocd62_overlap12_manifest.csv",
  "notes": [
    "OCD62 overlap12 RUN3 reproducibility rerun through OpenRouter.",
    "Backend label remains grok4 for analysis; model route is x-ai/grok-4.",
    "API key is provided at runtime and is not stored in this config.",
    "Physics protocol remains locked: MACE small on CPU with float32 precision and no dispersion."
  ]
}
