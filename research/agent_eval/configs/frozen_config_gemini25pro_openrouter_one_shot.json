{
  "llm_backend": "openrouter",
  "llm_model": "google/gemini-2.5-pro",
  "llm_base_url": "https://openrouter.ai/api/v1",
  "llm_api_key_env_var": "OPENROUTER_API_KEY",
  "temperature": 0.0,
  "max_tokens": 4096,
  "timeout_sec": 120,
  "max_retries": 1,
  "relaxation_mode": "standard",
  "calculator_backend": "mace",
  "mace_device": "cpu",
  "mace_precision": "float32",
  "mace_model": "small",
  "mace_use_dispersion": false,
  "fmax": 0.1,
  "random_seed": 42,
  "platform": "linux-x86_64-cpu-float32",
  "manifest_version": "ocd_gmae_representative50_manifest_v1",
  "transport_variant": "openrouter-official-gemini25pro-one-shot",
  "user_request_mode": "per-case explicit request string from manifests/ocd_gmae_representative50_manifest.csv",
  "notes": [
    "One-shot Gemini 2.5 Pro configuration for the representative 50-case OCD-GMAE run.",
    "Uses OpenRouter's official API endpoint instead of AiHubMix to reduce transport-specific failures.",
    "The target model is google/gemini-2.5-pro, matching OpenRouter model naming.",
    "API key is read from the OPENROUTER_API_KEY environment variable."
  ]
}
