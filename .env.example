# AdsMind local environment template.
# Copy to .env for local use. Do not commit real secrets.

# LLM backend: openrouter, openai, anthropic, ollama, or huggingface.
ADSMIND_LLM_BACKEND=openrouter

# Calculator backend. MACE is the default and currently primary backend.
ADSMIND_BACKEND=mace

# Hosted LLM API keys. Set only the key for the backend you use.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local backend options.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
HF_MODEL=Qwen/Qwen3-8B

# UI/agent guardrail for Streamlit runs.
AGENT_MAX_STEPS=20

# Optional visualization backend: ball-and-stick, space_fill, ovito, or catdt.
ADSMIND_VIS_RENDER_STYLE=ball-and-stick

